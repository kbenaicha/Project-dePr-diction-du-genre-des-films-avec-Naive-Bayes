      "source": [
        "# 6) Nettoyage\n",
        "\n",
        "df_clean = df_final.copy()\n",
        "\n",
        "# Remplacer '-' (ou chaînes vides) par NaN\n",
        "df_clean = df_clean.replace({\"-\": np.nan, \"\": np.nan, \" \": np.nan})\n",
        "\n",
        "# Timing(min): enlever 'min' et convertir\n",
        "df_clean[\"Timing(min)\"] = (\n",
        "    df_clean[\"Timing(min)\"].astype(str)\n",
        "      .str.replace(\"min\", \"\", regex=False)\n",
        "      .str.strip()\n",
        ")\n",
        "df_clean[\"Timing(min)\"] = pd.to_numeric(df_clean[\"Timing(min)\"], errors=\"coerce\")\n",
        "\n",
        "# Votes: enlever les virgules et convertir\n",
        "df_clean[\"Votes\"] = (\n",
        "    df_clean[\"Votes\"].astype(str)\n",
        "      .str.replace(\",\", \"\", regex=False)\n",
        "      .str.strip()\n",
        ")\n",
        "df_clean[\"Votes\"] = pd.to_numeric(df_clean[\"Votes\"], errors=\"coerce\")\n",
        "\n",
        "# Rating(10)\n",
        "df_clean[\"Rating(10)\"] = pd.to_numeric(df_clean[\"Rating(10)\"], errors=\"coerce\")\n",
        "\n",
        "# Budget / Revenue / Screens\n",
        "df_clean[\"Budget(INR)\"] = pd.to_numeric(df_clean[\"Budget(INR)\"], errors=\"coerce\")\n",
        "df_clean[\"Revenue(INR)\"] = pd.to_numeric(df_clean[\"Revenue(INR)\"], errors=\"coerce\")\n",
        "df_clean[\"Number of Screens\"] = pd.to_numeric(df_clean[\"Number of Screens\"], errors=\"coerce\")\n",
        "\n",
        "# Normaliser les catégorielles\n",
        "for c in [\"Release Period\", \"Genre\", \"New Music Director\", \"Language\"]:\n",
        "    df_clean[c] = df_clean[c].astype(str).str.lower().str.strip().replace({\"nan\": np.nan})\n",
        "\n",
        "print(\" Nettoyage terminé\")\n",
        "df_clean.info()\n"
      ]
    },
